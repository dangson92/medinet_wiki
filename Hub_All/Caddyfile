# Caddyfile — Medinet Wiki + MCP unified routing (Phase 5 + Quick task 2026-05-23)
#
# 2026-05-23: MCP service gộp về `wiki.medinet.vn/mcp` (path-prefix mode).
# Bỏ subdomain riêng `mcp.medinet.vn` — chỉ cần 1 DNS A record cho cả stack.
#
# Caddy reverse proxy + auto-TLS Let's Encrypt — cần port 80 + 443 + DNS trỏ
# về IP host. Domain truyền qua env `WIKI_PUBLIC_DOMAIN` (đọc từ .env compose):
#   - Prod: WIKI_PUBLIC_DOMAIN=wiki.medinet.vn → ACME Let's Encrypt thật
#   - Dev local: WIKI_PUBLIC_DOMAIN=localhost  → Caddy self-signed nội bộ
#
# MCP service self-mount dưới `/mcp` khi `MCP_PATH_PREFIX=mcp` (Phase 8.3 +
# Quick 2026-05-23 consolidation). Caddy KHÔNG strip prefix — SDK mcp tự xử
# lý `/mcp/*` Streamable HTTP transport + `/.well-known/oauth-*/mcp` suffix
# theo RFC 8414/9728 (Pitfall 7 carry forward Phase 8.3).
#
# Source: caddyserver.com/docs/caddyfile/* (path_regexp + handle_path + uri strip_prefix + try_files)
# Reference: .planning/phases/05-reverse-proxy-frontend-subpath/05-RESEARCH.md Pattern 1
{$WIKI_PUBLIC_DOMAIN:localhost} {
	# ─── Match 1: hub API routing (regex + strip prefix) ────────────────────
	# HUBS_ALLOWLIST_REGEX="yte|duoc|hcns" rendered from HUBS_ALLOWLIST env by hub-add.sh
	# path_regexp anchor ^/<hub>/api/ (T-5-01 open redirect mitigation — anchor required)
	@hub_api path_regexp hub_api ^/({$HUBS_ALLOWLIST_REGEX:yte|duoc|hcns})/api/(.*)$
	handle @hub_api {
		# Caddy `route` block — order significant; strip prefix TRƯỚC reverse_proxy
		# Upstream nhận /api/health (KHÔNG /yte/api/health) → M2 router code unchanged
		# Port STATIC :8080 (Pitfall 1 — placeholder upstream port không support)
		route {
			uri strip_prefix /{re.hub_api.1}
			# Pitfall 1 (05-RESEARCH §"Common Pitfalls"): Caddy CẤM placeholder
			# trong upstream address khi address có scheme (`http://`). Bỏ scheme
			# → Caddy default HTTP với port 8080 static; container name dynamic OK.
			reverse_proxy python-api-{re.hub_api.1}:8080 {
				header_up Host {host}
				header_up X-Real-IP {remote_host}
				header_up X-Forwarded-For {remote_host}
				header_up X-Forwarded-Proto {scheme}
				header_up X-Forwarded-Hub {re.hub_api.1}
			}
		}
	}

	# ─── Match 2: central API (KHÔNG strip) ─────────────────────────────────
	# Caddy auto-sort handle by matcher specificity (Pitfall 10) → @hub_api wins
	# khi URL match cả 2 (named matcher path_regexp specific hơn glob /api/*)
	handle /api/* {
		reverse_proxy http://python-api-central:8080 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ─── Match 3: MCP OAuth metadata (NEW 2026-05-23 — RFC 8414/9728 + OIDC) ─
	# Caddy auto-sort handle by path specificity — prefix dài
	# `/.well-known/oauth-authorization-server*` (40+ char) thắng catch-all
	# `/.well-known/*` JWKS Match 4 bên dưới (14 char). KHÔNG strip prefix —
	# SDK mcp serve metadata với suffix `/mcp` theo issuer path (Pitfall 7).
	handle /.well-known/oauth-authorization-server* {
		reverse_proxy medinet-mcp:8190
	}
	handle /.well-known/oauth-protected-resource* {
		reverse_proxy medinet-mcp:8190
	}
	handle /.well-known/openid-configuration* {
		reverse_proxy medinet-mcp:8190
	}

	# ─── Match 4: .well-known catch-all (Phase 3 JWKS central) ──────────────
	# /.well-known/jwks.json mount ở root central (KHÔNG /api/...) — explicit
	# handle TRƯỚC static SPA catch-all, otherwise file_server lookup 404
	# → JWKSCache fetch fail boot (Edge case Phase 3 Plan 03-01).
	# Match 3 trên thắng cho oauth-*; mọi `/.well-known/*` khác → central.
	handle /.well-known/* {
		reverse_proxy http://python-api-central:8080
	}

	# ─── Match 5: MCP path-prefix mount (NEW 2026-05-23 — consolidate) ──────
	# `MCP_PATH_PREFIX=mcp` ở mcp_service → SDK self-mount /mcp + Streamable
	# HTTP transport endpoint. KHÔNG strip prefix — upstream nhận đúng /mcp/...
	# Match `/mcp` exact + `/mcp/*` children (KHÔNG dùng /mcp* glob để tránh
	# match nhầm /mcp.html / /mcp-debug etc).
	handle /mcp {
		reverse_proxy medinet-mcp:8190
	}
	handle /mcp/* {
		reverse_proxy medinet-mcp:8190
	}

	# ─── Match 6: static SPA (catch-all fallback) ───────────────────────────
	# try_files {path} /index.html — SPA fallback cho /yte/dashboard, /login, etc
	# (Pitfall 2 — thiếu try_files → refresh F5 trên nested route 404 blank page)
	handle {
		root * /srv/wiki/dist
		try_files {path} /index.html
		file_server
	}

	# ─── Logging structured JSON ─────────────────────────────────────────────
	log {
		output stdout
		format json
		level INFO
	}
}
