# MCP Service — mẫu cấu hình môi trường (Phase 8.3 + Plan 10-04 CORS split)
# Copy sang .env và chỉnh theo môi trường triển khai. KHÔNG commit .env thật.

# === API Service backend — MCP service gọi qua HTTP ===
# Base URL của API Service (KHÔNG kèm /api). Chỉ chấp nhận scheme http hoặc https.
# Container Docker: MCP_API_BASE_URL=http://python-api:8080 (xem docker-compose.yml).
MCP_API_BASE_URL=http://localhost:8180

# Timeout (giây) cho mỗi request HTTP tới API Service.
MCP_HTTP_TIMEOUT=30

# === MCP service runtime ===
# Host và port MCP Service lắng nghe.
MCP_SERVICE_HOST=0.0.0.0
MCP_SERVICE_PORT=8190

# Routing mode — "mcp" cho path-prefix mode (/mcp/*), rỗng cho subdomain mode (mcp.domain).
# Phase 8.3 hỗ trợ cả 2 — Caddyfile + reverse proxy quyết định.
MCP_PATH_PREFIX=mcp

# === OAuth 2.0 (Phase 8.3 — Authorization Server + Resource Server) ===
# URL public HTTPS để Claude web kết nối connector. Prod PHẢI https domain thật
# (P-MCP-6 — issuer localhost làm hỏng discovery + redirect_uri).
# 2026-05-23: MCP gộp về wiki.<domain>/mcp (bỏ subdomain mcp.<domain>).
# Path suffix `/mcp` PHẢI khớp `MCP_PATH_PREFIX=mcp` ở dưới — sửa cả 2 cùng lúc.
MCP_OAUTH_ISSUER_URL=https://wiki.medinet.work/mcp

# File SQLite lưu OAuth state (clients/codes/tokens/pending).
# Docker: override /app/.oauth/state.db trên named volume medinet_mcp_oauth_state.
MCP_OAUTH_STATE_DB_PATH=.oauth/state.db

# Lifetime token OAuth (giây). Access 1 giờ + Refresh 30 ngày.
MCP_OAUTH_ACCESS_TOKEN_TTL=3600
MCP_OAUTH_REFRESH_TOKEN_TTL=2592000

# === Plan 10-04 CRIT-01 fix — CORS sensitive whitelist ===
# Tách 2 CORS policy theo path qua MultiPolicyCORSMiddleware:
#  - Metadata path (/.well-known/oauth-*, /.well-known/openid-configuration)
#    → ACAO * (RFC 8414 §3.1 + RFC 9728 §3.1)
#  - Sensitive path (/token, /authorize, /revoke, /register, /mcp[/*])
#    → echo whitelist origin (default 4 origin dưới đây)
# Comma-separated. KHÔNG có whitespace giữa item.
# Prod: thêm origin Claude Desktop nếu cần (https://claude.ai đã có).
MCP_OAUTH_SENSITIVE_ALLOWED_ORIGINS=https://claude.ai,https://inspector.modelcontextprotocol.io,http://localhost:6274,http://127.0.0.1:6274

# === Internal token cho API service gọi MCP internal endpoint ===
# Phase 8.3 per-user bind — API service dùng token này gọi MCP để verify OAuth user.
# Sinh random 32+ ký tự: `openssl rand -hex 32`. KHÔNG commit.
MCP_INTERNAL_TOKEN=CHANGEME_random_32_chars_min
