# ─── OCR ───
DOCLING_OCR_ENGINE=tesseract            # tesseract | rapidocr
DOCLING_OCR_LANGS=vie+eng

# ─── Tokenizer cho HybridChunker ───
DOCLING_TOKENIZER_NAME=cl100k_base      # default OpenAI text-embedding-3-*
DOCLING_MAX_TOKENS_PER_CHUNK=512

# ─── Limits ───
DOCLING_MAX_FILE_MB=50                  # 413 nếu vượt
DOCLING_REQUEST_TIMEOUT_SEC=180         # 504 nếu vượt

# ─── Logging ───
DOCLING_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
DOCLING_LOG_FORMAT=json                 # json | console

# ─── Service ───
DOCLING_HOST=0.0.0.0
DOCLING_PORT=8001
