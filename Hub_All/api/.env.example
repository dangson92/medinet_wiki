# Medinet Wiki API — .env.example (M2 production-ready, HARD-04 Plan 10-05)
# Copy file này thành .env và điền giá trị thực tế. KHÔNG commit .env.
# Đầy đủ 18 nhóm biến cần thiết cho FastAPI api/ chạy production-grade.

# === Hub identity (v3.0 Phase 1 TOPO-04) ===
# 1 codebase deploy nhiều lần với HUB_NAME khác nhau:
#   - "central"  → DB medinet_central (aggregator, expose toàn bộ endpoint)
#   - "yte"      → DB medinet_hub_yte (hub Y tế, endpoint hạn chế Phase 2)
#   - "duoc"     → DB medinet_hub_duoc (hub Dược)
#   - "hcns"     → DB medinet_hub_hcns (hub HCNS)
# Default "central" giữ backward-compat M2 deploy đơn.
# E-V3-3 enforce: DATABASE_URL phải khớp HUB_NAME (validator fail-fast startup).
HUB_NAME=central

# === Postgres (R1: pgvector ext bắt buộc dùng image pgvector/pgvector:pg16) ===
# Prod đổi POSTGRES_PASSWORD sang chuỗi random 32+ ký tự: `openssl rand -base64 32`
POSTGRES_PASSWORD=medinet_dev_pwd
# DATABASE_URL pattern theo HUB_NAME (chọn 1 — phải khớp HUB_NAME ở trên):
#   central  → postgresql+asyncpg://medinet:<pwd>@localhost:5432/medinet_central
#   yte      → postgresql+asyncpg://medinet:<pwd>@localhost:5432/medinet_hub_yte
#   duoc     → postgresql+asyncpg://medinet:<pwd>@localhost:5432/medinet_hub_duoc
#   hcns     → postgresql+asyncpg://medinet:<pwd>@localhost:5432/medinet_hub_hcns
DATABASE_URL=postgresql+asyncpg://medinet:medinet_dev_pwd@localhost:5432/medinet_central
COCOINDEX_DATABASE_URL=postgresql://medinet:medinet_dev_pwd@localhost:5432/medinet_cocoindex

# === Redis (cache search + rate limit slowapi + audit log queue) ===
REDIS_URL=redis://localhost:6379/0

# === CocoIndex (R5: APP_NAMESPACE cố định "medinet_prod" mọi env — xem CONVENTIONS.md) ===
APP_NAMESPACE=medinet_prod
COCOINDEX_DB_SCHEMA=cocoindex
# Sau khi `make migrate-up` xong: chạy `make cocoindex-setup` LẦN ĐẦU để
# cocoindex tự tạo bảng internal state trong schema `cocoindex`. Idempotent —
# Plan 04-02 ship flow.py xong sẽ chạy lại để register flow.

# === Cocoindex 1.0.3 LMDB local state (Q5 — Plan 04-03 RESEARCH.md Section 5) ===
# Cocoindex 1.0.3 lưu internal state (memo cache, fingerprint, lineage) trong
# LMDB filesystem local — KHÔNG dùng Postgres state nữa (cocoindex 0.x đã deprecated).
# COCOINDEX_DB env var = path đến LMDB directory. Cocoindex tự create nếu chưa tồn tại.
# .gitignored qua .cocoindex/ pattern (operator KHÔNG commit state).
COCOINDEX_DB=.cocoindex/state.lmdb
# Container override: /app/.cocoindex/state.lmdb (xem docker-compose.yml mcp_service env).
COCOINDEX_LMDB_PATH=.cocoindex

# === JWT keypair RS256 PKCS#8 (sinh bằng `make api-keys`) ===
# KHÔNG commit *.pem ra git. Mất private.pem = invalidate toàn bộ refresh token.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=900       # 15 phút (giây)
JWT_REFRESH_TOKEN_TTL=604800   # 7 ngày (giây)

# === File storage (local default — GDrive defer v4.0) ===
FILE_STORE_DIR=./file_store

# === LLM providers (Phase 7 ASK-04 hot-swap LiteLLM — D5) ===
# Prod BẮT BUỘC điền OPENAI_API_KEY tier paid. Eval gate ~$0.20/run.
OPENAI_API_KEY=sk-replace-me
GEMINI_API_KEY=replace-me
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
# R1 pgvector 2000-dim limit + R7 cross-dim swap REFUSE — KHÔNG đổi dim.
RAG_EMBEDDING_DIM=1536
RAG_LLM_PROVIDER=openai
RAG_LLM_MODEL=gpt-4o-mini

# === AES (API key encryption-at-rest — Phase 5 AUX-02, AES-256-GCM) ===
# BẮT BUỘC điền trước khi deploy production. 32-byte AES-256 key, base64.
# Sinh local: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# Placeholder dưới đây CHỈ để document — điền key thật vào .env (KHÔNG commit).
AES_KEY=CHANGEME_32_BYTES_BASE64_44_CHARS=

# === CORS (P12: prod chỉ origin HTTPS thật — validator _no_lan_in_prod reject localhost prod) ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Runtime ===
APP_ENV=dev
# 8180 — frontend api.ts hardcode (Hyper-V excluded range 8038-8137 trên Windows).
APP_PORT=8180
LOG_LEVEL=info
# Plan 10-01 HARD-01 — structlog JSON output (Docker capture native).
LOG_FORMAT=json

# === Rate limit (Phase 5 AUX-03 slowapi) ===
RATE_LIMIT_SEARCH_PER_MINUTE=100
RATE_LIMIT_UPLOAD_PER_MINUTE=30

# === Watchdog cocoindex (Phase 4 INGEST-06 — Plan 04-05) ===
# Heartbeat timeout — document stuck processing > N giây sẽ bị watchdog đánh status='failed_timeout'.
WATCHDOG_TIMEOUT_SECONDS=300
