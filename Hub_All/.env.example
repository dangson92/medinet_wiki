# Medinet Wiki — root .env.example
# File này là MẪU env cho `docker-compose.yml` ROOT (4 service hạ tầng).
# Sao chép thành `.env` trước khi `docker compose up`.
#
# KHÔNG trùng với:
#   - backend/.env.example       (env cho backend Go chạy native trên host)
#   - docling-pipeline/.env.example (env riêng cho service Docling Python sidecar)
#
# Khi `docker compose` đọc .env này: các biến override default value trong YAML
# (vd ${POSTGRES_PORT:-5432}).

# ─────────────── Postgres (service medinet-postgres) ───────────────
POSTGRES_DB=medinet_central
POSTGRES_USER=medinet
POSTGRES_PASSWORD=medinet_dev
POSTGRES_PORT=5432

# ─────────────── Redis (service medinet-redis) ───────────────
REDIS_PORT=6379

# ─────────────── ChromaDB (service medinet-chroma) ───────────────
CHROMA_PORT=8000

# ─────────────── Docling sidecar overrides ───────────────
# Các biến này override default trong docker-compose.yml; nếu để trống,
# compose dùng default trong YAML, sau đó docling-pipeline/.env (qua env_file)
# sẽ cung cấp giá trị runtime cho service Python.
DOCLING_OCR_ENGINE=tesseract
DOCLING_OCR_LANGS=vie+eng
DOCLING_TOKENIZER_NAME=cl100k_base
DOCLING_MAX_TOKENS_PER_CHUNK=512
DOCLING_MAX_FILE_MB=50
DOCLING_REQUEST_TIMEOUT_SEC=180
DOCLING_LOG_LEVEL=INFO
DOCLING_LOG_FORMAT=json

# ─────────────── Lưu ý ───────────────
# - Backend Go vẫn chạy NATIVE (make run trong backend/) — KHÔNG có service trong compose này.
# - Backend gọi docling-pipeline qua http://localhost:8001 (host network) khi backend native;
#   khi backend cũng dockerize ở milestone hardening, đổi URL thành http://docling-pipeline:8001.
# - Trước khi `docker compose up` lần đầu: backup ./chroma_data/ và stop Postgres/Chroma local
#   (nếu có) để tránh conflict port 5432/8000 và mount đè dữ liệu.
