# Medinet Wiki — root .env.example (M2 Full RAG Rewrite)
# File này là MẪU env cho `docker-compose.yml` ROOT (3 service: postgres + redis + python-api).
# Sao chép thành `.env` trước khi `docker compose up`.
#
# Backend service Go đã bị xoá ở TEARDOWN-01 (git tag m1-go-archived backup).
# Env riêng Python FastAPI: `api/.env` (xem `api/.env.example`).

# ─────────────── Postgres (service medinet-postgres, image pgvector/pgvector:pg16) ───────────────
# Password phải match api/.env DATABASE_URL.
POSTGRES_PASSWORD=medinet_dev_pwd

# ─────────────── App env ───────────────
APP_ENV=dev
LOG_LEVEL=info

# ─────────────── Reverse proxy + multi-hub routing (Phase 5 v3.0 — PROXY-01) ───────────────
# Phase 5 mở Caddy reverse proxy đa hub. Env này wire vào docker-compose.yml caddy service.
# 2026-05-23: MCP gộp về wiki.medinet.vn/mcp — bỏ MCP_PUBLIC_DOMAIN riêng (path-prefix mode
# qua MCP_PATH_PREFIX=mcp ở mcp_service/.env). Chỉ 1 DNS A record + 1 ACME cert cho cả stack.

# Domain serve qua HTTPS Caddy auto-TLS:
#   - Dev local: WIKI_PUBLIC_DOMAIN=localhost → Caddy self-signed cert (browser cảnh báo, chấp nhận)
#   - Prod: WIKI_PUBLIC_DOMAIN=wiki.medinet.work → Caddy auto ACME Let's Encrypt (cần port 80+443 open)
WIKI_PUBLIC_DOMAIN=localhost

# Hub allowlist — comma-separated. Operator add hub mới qua `make hub-add HUB=<name>` (Plan 02-05 FACTOR-04).
# Phase 5 thêm logic: hub-add.sh tự update HUBS_ALLOWLIST + HUBS_ALLOWLIST_REGEX cùng lúc + caddy reload.
# Tên hub phải match regex `^[a-z][a-z0-9_]{0,15}$` + tránh 6 reserved name (postgres/cocoindex/template0/template1/public/medinet).
HUBS_ALLOWLIST=yte,duoc,hcns

# Regex pipe-separated cho Caddy path_regexp matcher (auto-derived từ HUBS_ALLOWLIST).
# Phải sync với HUBS_ALLOWLIST — `make hub-add` cập nhật cả 2 atomic.
# Nếu sửa thủ công HUBS_ALLOWLIST, NHỚ render lại bằng: tr ',' '|' <<< $HUBS_ALLOWLIST
HUBS_ALLOWLIST_REGEX=yte|duoc|hcns

# ──────────────────────────────────────────────────────────────────────
# Phase 6 — System Settings Sync (Plan 06-01 SETTINGS-01..04 — 2026-05-23)
# ──────────────────────────────────────────────────────────────────────
# Shared secret cho hub con call central internal endpoint
# (POST /api/api-keys/verify). Required cả 4 service (central + 3 hub con).
# Min 32 char (Settings validator `_enforce_settings_proxy_secret` enforce —
# D-V3-Phase6-D LOCKED). docker-compose.yml fail-loud ${VAR:?msg} syntax truoc
# boot Settings validation. Generate prod:
#   openssl rand -hex 32
SETTINGS_PROXY_SECRET=replace-with-32-byte-hex-secret-from-openssl-rand-hex-32

# Cache TTL settings sync (D-V3-Phase6-B LOCKED). Default value match Settings field.
# 60s rag_config (pub/sub primary < 30s + TTL fallback Redis down)
# 300s hub_registry (rare-change FACTOR-04 `make hub-add` KHÔNG thường xuyên)
# 60s apikey (M2 AUX-02 hot revoke acceptable window)
SETTINGS_CACHE_TTL_RAG_CONFIG=60
SETTINGS_CACHE_TTL_HUB_REGISTRY=300
SETTINGS_CACHE_TTL_APIKEY=60

# Subscriber reconnect retry interval khi pubsub disconnect (fail-quiet, TTL natural fallback).
SETTINGS_SUBSCRIBER_RECONNECT_SECONDS=5

# ──────────────────────────────────────────────────────────────────────
# Phase 8.3 — MCP per-user pre-registered OAuth (shared secret API <-> MCP)
# ──────────────────────────────────────────────────────────────────────
# Shared secret giữa python-api-central và mcp_service cho endpoint internal
# GET /api/internal/mcp/clients/{client_id} — MCP gửi `Authorization: Bearer
# <token>` xuống API để verify per-user client `mcpu_*` (D-V3-Phase8.3-bind).
#
# Phải set Ở ĐÂY (ROOT .env) — KHÔNG set ở mcp_service/.env hay api/.env.
# docker-compose.yml wire qua ${MCP_INTERNAL_TOKEN:?msg} vào CẢ 2 container
# (python-api-central + mcp_service). Cùng 1 giá trị 2 chiều.
#
# Empty / thiếu → API trả 503 INTERNAL_AUTH_NOT_CONFIGURED → MCP /authorize
# trả 400 "Client ID not found" cho mọi client_id prefix mcpu_*.
#
# Gen prod: openssl rand -hex 32
MCP_INTERNAL_TOKEN=replace-with-32-byte-hex-secret-from-openssl-rand-hex-32

# URL public HTTPS Claude web kết nối connector MCP. Prod PHẢI https domain
# thật (P-MCP-6 — issuer localhost làm hỏng discovery + redirect_uri).
# Path suffix /mcp phải khớp MCP_PATH_PREFIX=mcp ở mcp_service/.env.
MCP_OAUTH_ISSUER_URL=https://wiki.medinet.work/mcp
